# ============================================================
# BOOTSTRAP: Copy this file to .env and fill in real secrets.
#   cp .env.example .env
#   # Then generate a JWT secret:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================

# Application
APP_NAME=Threat Intelligence API
ENVIRONMENT=local
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:5173"]

# PostgreSQL
POSTGRES_DB=police
POSTGRES_USER=police
POSTGRES_PASSWORD=police
DATABASE_URL=postgresql+asyncpg://police:police@db:5432/police

# Neo4j Graph DB
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# DB Connection Pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Redis / Celery
# REQUIRED: Set a strong password. Used by Redis --requirepass and all services that connect to it.
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/1

# Local object storage (replace minioadmin credentials before deployment!)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
# REQUIRED: Change this before running — must not remain "minioadmin"
MINIO_SECRET_KEY=replace-with-a-strong-minio-secret
MINIO_BUCKET=evidence

# Auth
# REQUIRED: Set JWT_SECRET_KEY to a 32+ byte random hex string.
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
ANALYST_USERNAME=analyst
# REQUIRED: Must not be "change-me". The app hashes this at startup with bcrypt.
ANALYST_PASSWORD=replace-with-a-strong-analyst-password
INTERNAL_API_KEYS=["dev-internal-key"]

# Gunicorn (production only — used by docker-compose.prod.yml)
# Formula: (2 × CPU_cores) + 1. Example: 4-core machine → 9
GUNICORN_WORKERS=2

# Risk / alert thresholds
RISK_THRESHOLD_HIGH=65
RISK_THRESHOLD_CRITICAL=85
ALERT_WEBHOOK_URL=
INTELLIGENCE_CONFIDENCE_THRESHOLD=0.5

# Reddit Collector
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Format: <platform>:<app_name>:<version> (by u/<reddit_username>)
REDDIT_USER_AGENT=
REDDIT_SUBREDDITS=["subreddit1", "subreddit2"]
REDDIT_POLL_INTERVAL_MINUTES=15
REDDIT_FETCH_LIMIT=50

# Telegram Collector
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_CHANNELS=["channel1", "channel2"]
TELEGRAM_POLL_INTERVAL_MINUTES=15
TELEGRAM_FETCH_LIMIT=50

# Mock X Collector
# These settings are mock-only until real API access is available
X_ACCOUNTS=["account1", "account2"]
X_POLL_INTERVAL_MINUTES=15
X_FETCH_LIMIT=50

# Graph Discovery Engine
MAX_BFS_DEPTH=3
GRAPH_NEW_CHANNELS_PER_CYCLE=5
